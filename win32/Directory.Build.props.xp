<!--
  Windows XP compatibility override.

  To build with Windows XP support (requires VS2017 with v141_xp toolset):
    1. Rename this file to Directory.Build.props
    2. Open the solution in VS2017 and build

  This restores the v141_xp toolset and Windows 8.1 SDK for XP targeting.
-->
<Project>
  <PropertyGroup>
    <PlatformToolset>v141_xp</PlatformToolset>
    <WindowsTargetPlatformVersion>8.1</WindowsTargetPlatformVersion>
  </PropertyGroup>
</Project>
